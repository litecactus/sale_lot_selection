<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_lot_column" model="ir.ui.view">
        <field name="name">stock.picking.form.lot.column</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Show the Serial/Lot column on the delivery Operations list by
                 default instead of hiding it in the optional columns menu. -->
            <xpath expr="//field[@name='move_ids']//field[@name='lot_ids']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
        </field>
    </record>
</odoo>
